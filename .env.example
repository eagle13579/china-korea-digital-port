# ============================================================
# 中韩出海数智港 (China-Korea Digital Port) 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据需要修改:
#   cp .env.example .env
# ============================================================

# --- 管理员认证 ---
# 管理员用户名（默认: admin）
ADMIN_USER=admin

# 管理员密码（默认: admin123，生产环境务必修改！）
ADMIN_PASS=admin123

# Token 生成密钥（默认: china-korea-digital-port-2026）
TOKEN_SECRET=china-korea-digital-port-2026

# --- CORS 跨域配置 ---
# 允许的跨域来源，多个用逗号分隔
# 设为 * 表示允许所有来源（开发模式）
# 生产环境应设为具体域名，例如: https://go-aiport.com,https://admin.go-aiport.com
ALLOWED_ORIGINS=*

# --- 数据库配置 ---
# 数据库文件存储目录（默认: backend/data/）
# 可设为绝对路径或相对路径
DB_DIR=
