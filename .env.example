# ============================================================
# 中韩出海数智港 (China-Korea Digital Port) 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据需要修改:
#   cp .env.example .env
# ============================================================

# --- 管理员认证 ---
# 管理员用户名（必填！无默认值，系统启动时会验证）
# 安全说明：生产环境务必使用强密码，不要与其他系统共用密码
ADMIN_USERNAME=your_admin_username_here

# 管理员密码（必填！无默认值，系统启动时会验证）
# 安全说明：建议使用 16 位以上包含大小写字母、数字和特殊字符的密码
ADMIN_PASSWORD=your_strong_password_here

# Token 生成密钥（建议修改为随机字符串，生产环境务必修改！）
# 可通过以下命令生成：openssl rand -hex 32
TOKEN_SECRET=change_this_to_a_random_secret_key

# --- CORS 跨域配置 ---
# 允许的跨域来源，多个用逗号分隔
# 设为 * 表示允许所有来源（开发模式）
# 生产环境应设为具体域名，例如: https://go-aiport.com,https://admin.go-aiport.com
ALLOWED_ORIGINS=*

# --- 数据库配置 ---
# 数据库文件存储目录（默认: backend/data/）
# 可设为绝对路径或相对路径
DB_DIR=

# --- 支付宝当面付配置 (Alipay Face-to-Face) ---
# APP_ID: 支付宝开放平台应用的 APPID
ALIPAY_APP_ID=your_alipay_app_id_here

# 商户私钥路径 (应用私钥，PKCS1 或 PKCS8 格式)
# 由 OpenSSL 生成: openssl genrsa -out certs/alipay_app_private_key.pem 2048
# 支持绝对路径或相对项目根目录的路径
ALIPAY_APP_PRIVATE_KEY=./certs/alipay_app_private_key.pem

# 支付宝公钥路径 (用于验证支付宝的通知签名)
# 在支付宝开放平台获取
ALIPAY_PUBLIC_KEY=./certs/alipay_public_key.pem

# 是否沙箱模式 (true=使用沙箱环境, false=生产环境)
ALIPAY_SANDBOX=true

# 支付结果通知地址 (需公网可访问，用于接收支付宝异步通知)
ALIPAY_NOTIFY_URL=https://go-aiport.com/api/v1/payment/notify
